---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <style is:global>
    :root {
      --primary: #d35400;
      --bg: #fff8f0;
      --text: #333;
    }
    body { margin:0; font-family:sans-serif; background:var(--bg); color:var(--text); }
    .hero { background:var(--primary); color:#fff; text-align:center; padding:4rem 2rem; }
    .logo { width:150px; height:150px; border-radius:50%; object-fit:cover; margin-bottom:1rem; }
    .hero h1 { margin:0.5rem 0; font-size:2.5rem; }
    .hero p { margin:0; font-size:1.2rem; opacity:0.9; }
    .buttons { margin-top:2rem; }
    .btn { display:inline-block; background:#fff; color:var(--primary); padding:0.8rem 1.5rem; margin:0.5rem; border-radius:5px; text-decoration:none; font-weight:bold; }
    .hero .btn { background:rgba(255,255,255,0.2); color:#fff; }
    .hero .btn:hover { background:rgba(255,255,255,0.3); }
    section { padding:3rem 2rem; max-width:960px; margin:auto; }
    h2 { text-align:center; margin-bottom:1.5rem; color:var(--primary); }
    .grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(150px, 1fr)); gap:1.5rem; justify-content:center; }
    .item { text-align:center; border:1px solid #ddd; border-radius:8px; padding:0.75rem; background:#fff; display:flex; flex-direction:column; align-items:center; justify-content:center; overflow:hidden; min-height:175px; }
    .item img { width:80px; height:80px; object-fit:cover; border-radius:8px; margin-bottom:0.5rem; }
    .item p { margin:0; font-size:0.9rem; }
    iframe { border:none; border-radius:8px; width:100%; height:300px; }
    .order-btns { display:flex; justify-content:center; gap:1.5rem; margin-top:1.5rem; flex-wrap:wrap; }
    .order-btns .btn { background:var(--primary); color:#fff; }
    .order-btns .btn:hover { opacity:0.9; }
    .loading { text-align:center; color:#999; padding:2rem; }
    @media (max-width:600px) {
      .hero { padding:3rem 1rem; }
      .hero h1 { font-size:2rem; }
      section { padding:2rem 1rem; }
      .grid { grid-template-columns:repeat(auto-fill, minmax(130px, 1fr)); gap:1rem; }
      .item { min-height:150px; padding:0.6rem; }
      .item img { width:60px; height:60px; }
    }
  </style>
  <header class="hero">
    <img src="/favicon.png" alt="Logo" class="logo" loading="eager" />
    <h1>Welcome Sweets</h1>
    <p>Freshly baked sweets &amp; savories</p>
    <div class="buttons">
      <a href="/menu" class="btn">Menu</a>
      <a href="#location" class="btn">Location</a>
    </div>
  </header>
  <section id="about">
    <h2>About Us</h2>
    <p>We serve delicious sweets and savory snacks made fresh daily.</p>
  </section>
  <section id="menu-preview">
    <h2>Popular Items</h2>
    <div class="grid" id="popular-grid">
      <p class="loading">Loading…</p>
    </div>
  </section>
  <section id="location">
    <h2>Visit Us</h2>
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3504.123456789012!2d77.123456!3d28.654321!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390d04...!2sWelcome%20Sweets!5e0!3m2!1sen!2sin!4v1600000000000"
      allowfullscreen="" loading="lazy"></iframe>
  </section>
  <section id="order">
    <h2>Order Online</h2>
    <div class="order-btns">
      <a href="https://www.swiggy.com" target="_blank" class="btn swiggy">Order on Swiggy</a>
      <a href="https://www.zomato.com" target="_blank" class="btn zomato">Order on Zomato</a>
    </div>
  </section>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script is:inline>
  const SUPABASE_URL = 'https://jfvgsaiobwaozbsdnaec.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpmdmdzYWlvYndhb3pic2RuYWVjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIyMDE5MDQsImV4cCI6MjA5Nzc3NzkwNH0.4WwDK2PKkrQ5DAASvCuEWToXDNadUMFOesPluVSrEBk';
  const supa = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  async function loadPopular() {
    const grid = document.getElementById('popular-grid');
    try {
      const { data, error } = await supa
        .from('menu_items')
        .select('name, image_url')
        .eq('popular', true)
        .limit(6);

      if (error || !data || data.length === 0) {
        grid.innerHTML = '<p class="loading">No popular items yet.</p>';
        return;
      }

      grid.innerHTML = data.map(item => `
        <div class="item">
          <img src="${(item.image_url || '/favicon.svg').replace(/"/g, '&quot;')}" alt="${(item.name || '').replace(/"/g, '&quot;')}" loading="lazy" />
          <p>${(item.name || '').replace(/</g, '&lt;')}</p>
        </div>`).join('');
    } catch (e) {
      grid.innerHTML = '<p class="loading">Could not load items.</p>';
      console.warn('Popular items load error:', e);
    }
  }
  loadPopular();
</script>
