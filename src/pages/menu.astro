---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <style is:global>
    :root {
      --primary: #d35400;
      --bg: #fff8f0;
      --text: #333;
    }
    body { margin:0; font-family:sans-serif; background:var(--bg); color:var(--text); }
    header { text-align:center; padding:3rem 1rem; background:var(--primary); color:#fff; }
    header img { width:80px; height:80px; border-radius:50%; object-fit:cover; margin-bottom:1rem; }
    header h1 { margin:0.5rem 0; font-size:2rem; }
    header p { margin:0; opacity:0.9; }
    section { max-width:960px; margin:auto; padding:2rem; }
    h2 { color:var(--primary); text-align:center; margin-top:2rem; }
    .category { margin-top:2rem; }
    .category h3 { border-bottom:2px solid var(--primary); padding-bottom:0.3rem; display:inline-block; margin-bottom:0.5rem; }
    .items { display:grid; grid-template-columns:repeat(auto-fill, minmax(150px, 1fr)); gap:1.5rem; margin-top:1rem; justify-content:center; }
    .item { text-align:center; border:1px solid #ddd; border-radius:8px; padding:0.75rem; background:#fff; display:flex; flex-direction:column; align-items:center; justify-content:center; overflow:hidden; min-height:175px; }
    .item img { width:80px; height:80px; object-fit:cover; border-radius:8px; margin-bottom:0.5rem; }
    .item h4 { margin:0.3rem 0; font-size:0.9rem; line-height:1.2; }
    .item p { margin:0; color:#666; font-size:0.8rem; line-height:1.3; }
    .item .price { font-weight:bold; color:var(--primary); margin-top:0.4rem; font-size:0.85rem; }
    .btn { display:inline-block; background:var(--primary); color:#fff; padding:0.8rem 1.5rem; border-radius:5px; text-decoration:none; margin-top:2rem; }
    .btn:hover { opacity:0.9; }
    .loading { text-align:center; color:#999; padding:2rem; }
    .empty { text-align:center; color:#999; font-style:italic; padding:1rem; }
    @media (max-width:480px) {
      section { padding:1.5rem 1rem; }
      .items { grid-template-columns:repeat(auto-fill, minmax(130px, 1fr)); gap:1rem; }
      .item { min-height:150px; padding:0.6rem; }
      .item img { width:60px; height:60px; }
      .item h4 { font-size:0.8rem; }
    }
  </style>
  <header>
    <img src="/favicon.png" alt="Logo" loading="eager" />
    <h1>Our Menu</h1>
    <p>Explore our delicious sweets and savories</p>
  </header>
  <section id="menu-container">
    <p class="loading">Loading menu…</p>
  </section>
  <section style="text-align:center; margin-top:2rem;">
    <a href="/" class="btn">← Back to Home</a>
  </section>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script is:inline>
  const SUPABASE_URL = 'https://jfvgsaiobwaozbsdnaec.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpmdmdzYWlvYndhb3pic2RuYWVjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIyMDE5MDQsImV4cCI6MjA5Nzc3NzkwNH0.4WwDK2PKkrQ5DAASvCuEWToXDNadUMFOesPluVSrEBk';
  const supa = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  async function loadMenu() {
    const container = document.getElementById('menu-container');
    try {
      const [catRes, itemRes] = await Promise.all([
        supa.from('categories').select('*').order('sort_order'),
        supa.from('menu_items').select('*').order('sort_order'),
      ]);
      const categories = catRes.data || [];
      const menuItems = itemRes.data || [];

      if (categories.length === 0) {
        container.innerHTML = '<p class="loading">Menu coming soon!</p>';
        return;
      }

      container.innerHTML = categories.map(cat => {
        const catItems = menuItems.filter(i => i.category_id === cat.id);
        const itemsHtml = catItems.length > 0
          ? catItems.map(item => `
              <div class="item">
                <img src="${(item.image_url || '/favicon.svg').replace(/"/g, '&quot;')}" alt="${(item.name || '').replace(/"/g, '&quot;')}" loading="lazy" />
                <h4>${(item.name || '').replace(/</g, '&lt;')}</h4>
                <p>${(item.description || '').replace(/</g, '&lt;')}</p>
                ${item.price ? `<p class="price">${(item.price || '').replace(/</g, '&lt;')}</p>` : ''}
              </div>`).join('')
          : '<p class="empty">No items in this category yet.</p>';

        return `
          <div class="category">
            <h3>${(cat.name || '').replace(/</g, '&lt;')}</h3>
            <div class="items">${itemsHtml}</div>
          </div>`;
      }).join('');
    } catch (e) {
      container.innerHTML = '<p class="loading">Could not load menu. Please try again later.</p>';
      console.warn('Menu load error:', e);
    }
  }
  loadMenu();
</script>
